# Database (Supabase connection string or any PostgreSQL URL):
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT secrets — set strong random values in production:
JWT_ACCESS_SECRET=changeme
JWT_REFRESH_SECRET=changeme
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Optional — leave unset to use relative /api/v1 routing (recommended for Vercel):
# NEXT_PUBLIC_API_URL=https://your-app.vercel.app/api/v1

# Anthropic API key — required for the AI Analysis module:
ANTHROPIC_API_KEY=sk-ant-...

# Environment indicator — set to "staging" in Vercel Preview env vars, leave unset for production:
# NEXT_PUBLIC_APP_ENV=staging
