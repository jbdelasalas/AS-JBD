NODE_ENV=development
PORT=4000

# ---------------------------------------------------------------------------
# Database — pick ONE approach
# ---------------------------------------------------------------------------

# Local development (default):
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=perpet_erp

# Production / Supabase: set DATABASE_URL instead of the DB_* vars above.
# When DATABASE_URL is set, the DB_* vars are IGNORED.
#
# Get this from Supabase → Project Settings → Database → "Connection string" →
# "Session" pooler (port 5432) for long-running services like Railway.
# (Use the "Transaction" pooler / port 6543 only for serverless / edge environments.)
#
# Example:
# DATABASE_URL=postgres://postgres.PROJECTREF:YOURPASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ---------------------------------------------------------------------------
# Auth — change these in production!
# ---------------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ---------------------------------------------------------------------------
# CORS — comma-separated allowed origins. Wildcards (*) are supported.
# ---------------------------------------------------------------------------
# Local:
WEB_ORIGIN=http://localhost:3000
# Production with Vercel previews:
# WEB_ORIGIN=https://perpet-erp.vercel.app,https://*.vercel.app
